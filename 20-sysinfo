#!/bin/bash

# get load averages
IFS=" " read LOAD1 LOAD5 LOAD15 <<<$(awk '{ print $1,$2,$3 }' /proc/loadavg)
# get free memory
IFS=" " read USED AVAIL TOTAL <<<$(free -htm | awk '/Mem/ { print $3,$7,$2 }')
# get processes
PROCESS=$(ps -eo user= | sort | uniq -c | awk '{ print $2 " " $1 }')
PROCESS_ALL=$(echo "$PROCESS" | awk '{ SUM += $2 } END { print SUM }')
PROCESS_ROOT=$(echo "$PROCESS" | awk '/^root / { print $2 }')
PROCESS_USER=$(echo "$PROCESS" | awk '!/^root / { SUM += $2 } END { print SUM }')
# get processors
PROCESSOR_NAME=$(awk -F': ' '/model name/ { print $2; exit }' /proc/cpuinfo)
PROCESSOR_COUNT=$(grep -c 'processor' /proc/cpuinfo)

# colors
r=$'\e[0m'
bold=$'\e[1m'
dim=$'\e[2m'
green=$'\e[1;32m'
orange=$'\e[38;5;208m'
red=$'\e[1;31m'
yellow=$'\e[1;33m'
cyan=$'\e[0;36m'

# color load value based on per-cpu ratio
load_color() {
    local key
    key=$(awk -v v="$1" -v c="$PROCESSOR_COUNT" \
        'BEGIN { r=v/c; if(r<0.7) print "green"; else if(r<1.0) print "yellow"; else print "red" }')
    case $key in
        green)  printf '%s' "$green" ;;
        yellow) printf '%s' "$yellow" ;;
        *)      printf '%s' "$red" ;;
    esac
}

L1C=$(load_color $LOAD1)
L5C=$(load_color $LOAD5)
L15C=$(load_color $LOAD15)

DISTRO=$(grep PRETTY_NAME /etc/os-release | cut -d= -f2- | tr -d '"')
KERNEL=$(uname -r)

printf "\n${bold}system:${r}\n"
printf "  ${dim}distro${r}   ${orange}%s${r} ${dim}(%s)${r}\n"  "$DISTRO" "$KERNEL"
printf "  ${dim}uptime${r}   %s\n"                              "$(uptime -p)"
printf "  ${dim}load${r}     ${L1C}%s${r} ${dim}1m${r}   ${L5C}%s${r} ${dim}5m${r}   ${L15C}%s${r} ${dim}15m${r}\n" \
    "$LOAD1" "$LOAD5" "$LOAD15"
printf "  ${dim}procs${r}    ${green}%s${r} ${dim}root${r}   ${green}%s${r} ${dim}user${r}   ${green}%s${r} ${dim}total${r}\n" \
    "$PROCESS_ROOT" "$PROCESS_USER" "$PROCESS_ALL"
printf "\n"
printf "  ${dim}cpu${r}      ${cyan}%s${r} ${dim}×${r}${green}%s${r}\n" "$PROCESSOR_NAME" "$PROCESSOR_COUNT"
printf "  ${dim}memory${r}   ${orange}%s${r} ${dim}used${r}   ${green}%s${r} ${dim}avail${r}   %s ${dim}total${r}\n\n" \
    "$USED" "$AVAIL" "$TOTAL"
