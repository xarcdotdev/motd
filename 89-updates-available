#!/bin/bash

stamp="/var/lib/update-notifier/updates-available"
[ ! -r "$stamp" ] && exit 0

find "$stamp" -newermt 'now-7 days' 2>/dev/null | grep -q -m1 '.' || /usr/share/update-notifier/notify-updates-outdated

total=$(grep -oP '^\d+(?= updates can be applied)' "$stamp")
[ -z "$total" ] && exit 0

security=$(grep -oP '^\d+(?= of these updates (is|are) a standard security)' "$stamp")
esm=$(grep -oP '^\d+(?= additional security updates can be applied with ESM)' "$stamp")

r=$'\e[0m'
dim=$'\e[2m'
yellow=$'\e[1;33m'
red=$'\e[1;31m'
orange=$'\e[38;5;208m'
undim="\e[0m"

detail=""
[ -n "$security" ] && [ "$security" -gt 0 ] && detail="${red}${security}${r} ${dim}security${r}"
[ -n "$esm" ]      && [ "$esm" -gt 0 ]      && detail="${detail:+$detail${dim}, ${r}}${orange}${esm}${r} ${dim}esm${r}"
[ -n "$detail" ] && detail=" ${dim}(${r}${detail}${dim})${r}"

printf "\n${undim}updates:${r} ${yellow}%s${r} ${dim}available${r}%s\n" "$total" "$detail"
